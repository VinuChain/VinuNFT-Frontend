{
    "name": "vinu-nft",
    "version": "1.0.0",
    "private": true,
    "description": "VinuChain text and image NFT dapp.",
    "engines": {
        "node": ">=18 <23"
    },
    "contributors": [
        "Samuele Marro",
        "Luca Donno"
    ],
    "keywords": [
        "gatsby"
    ],
    "scripts": {
        "dev": "gatsby develop",
        "start": "gatsby develop",
        "build": "gatsby build && yarn add-csp",
        "lint": "eslint --ext .js src gatsby-browser.js gatsby-config.js gatsby-node.js gatsby-ssr.js add_csp.js",
        "test": "node --import tsx --test test/*.test.js test/*.test.mjs",
        "audit:triage": "node scripts/audit-triage.js",
        "verify": "yarn lint && yarn test",
        "serve": "gatsby serve",
        "clean": "gatsby clean",
        "prepare": "husky install",
        "precommit": "lint-staged",
        "add-csp": "node add_csp.js"
    },
    "lint-staged": {
        "*.js": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^1.2.36",
        "@fortawesome/free-solid-svg-icons": "^5.15.4",
        "@fortawesome/react-fontawesome": "^0.1.16",
        "@geoffcox/react-splitter": "^2.1.1",
        "@hookform/resolvers": "^2.8.0",
        "@uiw/react-md-editor": "^3.9.3",
        "ace-builds": "^1.4.14",
        "assert": "^2.0.0",
        "browserify-fs": "^1.0.0",
        "browserslist": "^4.17.0",
        "buffer": "^6.0.3",
        "bulma": "^0.9.3",
        "bulma-extensions": "^6.2.7",
        "crypto-browserify": "^3.12.0",
        "decimal.js": "^10.3.1",
        "dotenv": "^10.0.0",
        "eth-provider": "^0.13.7",
        "ethers": "^5.5.2",
        "file-loader": "^6.2.0",
        "gatsby": "^5.13.7",
        "gatsby-plugin-csp": "^1.1.4",
        "gatsby-plugin-csp-nonce": "^1.2.0",
        "gatsby-plugin-react-helmet": "^4.14.0",
        "gatsby-source-filesystem": "^3.14.0",
        "https-browserify": "^1.0.0",
        "husky": "^7.0.4",
        "javascript-time-ago": "^2.3.13",
        "joi": "^17.4.2",
        "lint-staged": "^12.3.7",
        "net-browserify": "^0.2.4",
        "os-browserify": "^0.3.0",
        "path-browserify": "^1.0.1",
        "process": "^0.11.10",
        "query-string": "^7.0.1",
        "react": "18",
        "react-ace": "^9.5.0",
        "react-dom": "18",
        "react-drag-drop-files": "^2.3.10",
        "react-helmet": "^6.1.0",
        "react-hook-form": "^7.15.3",
        "react-infinite-scroll-component": "^6.1.0",
        "react-loading-skeleton": "^3.0.3",
        "react-modal": "^3.14.3",
        "react-toastify": "^8.2.0",
        "react-tooltip": "^4.2.21",
        "recoil": "^0.5.2",
        "recoil-persist": "^5.1.0",
        "rehype-parse": "^8.0.4",
        "rehype-react": "^7.0.4",
        "rehype-sanitize": "^5.0.0",
        "rehype-stringify": "^9.0.3",
        "sanitize-html": "^2.7.0",
        "stream-browserify": "^3.0.0",
        "stream-http": "^3.2.0",
        "tls-browserify": "^0.2.2",
        "unified": "^10.1.2",
        "url-polyfill": "^1.1.12",
        "web3modal": "^1.9.4",
        "ws": "^8.2.2",
        "zlib-browserify": "^0.0.3"
    },
    "devDependencies": {
        "eslint": "^7.32.0",
        "eslint-plugin-react": "^7.26.0",
        "htmlparser2": "^9.1.0",
        "prettier": "2.6.1",
        "tsx": "^4.22.4"
    },
    "packageManager": "yarn@1.22.22"
}
