GATSBY_ALCHEMY_API_KEY=
GATSBY_ALCHEMY_MAINNET_API_KEY=
GATSBY_IPFS_UPLOAD_ENDPOINT=/api/upload-ipfs

# Server-side only. Never prefix this with GATSBY_.
PINATA_API_JWT=
# Allowlist-only image upload MVP. Public uploads require durable rate limiting first.
PINATA_ALLOWED_UPLOAD_ADDRESSES=
PINATA_MAX_UPLOAD_BYTES=10485760
PINATA_MAX_UPLOADS_PER_WINDOW=20
PINATA_MAX_GLOBAL_UPLOADS_PER_WINDOW=200
TRUSTED_CLIENT_IP_HEADER=
